{
  "cli": {
    "version": ">= 20.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://bjj-flow-production.up.railway.app/api/v1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://bjj-flow-production.up.railway.app/api/v1"
      }
    },
    "testflight": {
      "extends": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
